[user]
	name = Masayoshi Mizutani
	email = masayoshi.mizutani@dr-ubie.com
[merge "mergepbx"]
	name = Xcode project files merger
	driver = mergepbx %O %A %B
	note = auto-generated configuration by cpad2 upgrade

[submodule]
    recurse = true

[alias]
    d = diff -b --word-diff
    co = checkout
    cob = checkout -b
    c = commit
    s = status -s
    br = branch
    sw = switch
    swc = switch -c
    l = log --graph --date=short --decorate=short --pretty=format:'%Cgreen%h %Creset%cd\n%Cblue%cn %Cred%d %Creset%s'
    rollback = reset @~1
    r = reset @~1
    wip = commit -a -m wip
    unwip = reset @~1
    logg = log --stat --graph --decorate=full
    loggg = log --stat --graph --format=fuller
    logdiff = log -p -b -5
    ls = stash list
    unstage = reset HEAD
    superpull = pull upstream master
    superpush = ! git push -u origin $(git rev-parse --abbrev-ref HEAD)
    h = rev-parse --short HEAD
    lh = rev-parse HEAD
    ph = push origin HEAD
    aic = "!f() { COMMITMSG=$(git diff --cached | claude --no-session-persistence --model claude-haiku-4-5 --print 'You are generating a Conventional Commit message. Based strictly on the provided git diff, generate ONLY a one-line commit message using the Conventional Commits specification. Format: <type>(optional-scope): <imperative summary>. Rules: Use one of these types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert. Write the summary in imperative mood. Maximum ~72 characters. Do NOT include body text or explanation. Output ONLY the commit message line.'); git commit -m \"$COMMITMSG\" -e; }; f"
[ghq]
    root = ~/.ghq
[hub]
	host = ghe.ckpd.co
[core]
	symlinks = false
	editor = vim
[pull]
	rebase = false
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
