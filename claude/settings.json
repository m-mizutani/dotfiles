{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:zenn.dev)",
      "WebSearch",
      "Bash(npm run lint)",
      "Bash(npm run test:*)",
      "Bash(go test:*)",
      "Bash(go run:*)",
      "Bash(go mod:*)",
      "Bash(go get:*)",
      "Bash(go vet:*)",
      "Bash(go fmt:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(mkdir:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(gh run list:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run view:*)",
      "Read(//Users/mizutani/.cache/go/pkg/**)",
      "WebFetch(domain:api.slack.com)",
      "WebFetch(domain:docs.slack.dev)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(sed:*)",
      "Bash(go build:*)",
      "Bash(kill:*)",
      "Bash(*/python* *)",
      "Bash(python* *)",
      "Bash(*/node *)",
      "Bash(node *)",
      "Bash(bash *)",
      "Bash(*/bash *)",
      "Bash(sh *)",
      "Bash(*/sh *)",
      "Bash(zsh *)",
      "Bash(*/zsh *)",
      "Bash(csh *)",
      "Bash(*/csh *)",
      "Bash(tcsh *)",
      "Bash(*/tcsh *)",
      "Bash(ksh *)",
      "Bash(*/ksh *)",
      "Bash(fish *)",
      "Bash(*/fish *)",
      "Bash(dash *)",
      "Bash(*/dash *)",
      "Bash(go run *)",
      "Bash(*/go run *)",
      "Bash(curl *)",
      "Bash(*/curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(sed *)",
      "Bash(npx *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git -C *)",
      "Bash(chmod *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "mcp__claude_ai_Slack"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/mizutani/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "language": "FGOの魔術師マーリン",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "excludedCommands": [
      "git:*",
      "gh:*",
      "gcloud:*",
      "docker:*",
      "bq:*",
      "npx difit:*",
      "zenv:*"
    ],
    "filesystem": {
      "allowWrite": [
        "//tmp/claude-work",
        "~/.npm",
        "~/.cache",
        "~/.agent-browser",
        "~/Library/Caches"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.azure",
        "~/.config/gcloud",
        "~/.config/gh",
        "~/.docker/config.json",
        "~/.kube",
        "~/.npmrc",
        "~/.pypirc",
        "~/.netrc",
        "~/.git-credentials",
        "~/.password-store",
        "~/.local/share/keyrings",
        "~/.gnome2/keyrings",
        "~/.kde/share/apps/kwallet",
        "~/.config/hub",
        "~/.config/op",
        "~/.config/configstore",
        "~/.terraform.d/credentials.tfrc.json",
        "~/.vault-token",
        "~/.config/sops",
        "~/.config/age",
        "~/.age",
        "~/.secrets",
        "~/.secrets.yaml",
        "~/.config/heroku",
        "~/.config/vercel",
        "~/.config/netlify",
        "~/.config/firebase",
        "~/.config/stripe",
        "~/.config/twilio",
        "~/.config/circleci",
        "~/.pulumi/credentials.json",
        "~/.sentryclirc",
        "~/.config/snyk",
        "~/.sup",
        "~/.config/helm",
        "~/.config/doctl",
        "~/.config/linode-cli",
        "~/.config/hcloud",
        "~/.fly",
        "~/.dbt/profiles.yml",
        "~/.pgpass",
        "~/.my.cnf",
        "~/.mongoshrc.js",
        "~/.rediscli_history",
        "~/.config/redis",
        "~/.claude/settings.json",
        "~/.claude/settings.local.json",
        "~/.bash_history",
        "~/.zsh_history",
        "~/.node_repl_history",
        "~/.python_history",
        "~/.psql_history",
        "~/.mysql_history",
        "~/.irb_history",
        "//etc/shadow",
        "//etc/gshadow",
        "//etc/sudoers",
        "//etc/ssl/private",
        "//etc/pki"
      ],
      "denyWrite": [
        "//etc",
        "//usr",
        "//bin",
        "//sbin",
        "//opt",
        "//var",
        "//System",
        "//Library",
        "~/.ssh",
        "~/.gnupg",
        "~/.bashrc",
        "~/.bash_profile",
        "~/.zshrc",
        "~/.zprofile",
        "~/.profile",
        "~/.config/fish",
        "~/.claude/settings.json",
        "~/.claude/settings.local.json"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org"
      ],
      "allowLocalBinding": true
    }
  },
  "effortLevel": "medium",
  "autoUpdatesChannel": "stable"
}
