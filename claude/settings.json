{
  "agentPushNotifEnabled": true,
  "askUserQuestionTimeout": "never",
  "autoUpdatesChannel": "stable",
  "enabledPlugins": {
    "epic@m-mizutani-plugins": true,
    "goast-policy@goast": true,
    "gopls-lsp@claude-plugins-official": true,
    "sentry-mcp@sentry-mcp": true,
    "skill-creator@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_AFK_COUNTDOWN_MS": "2147483647",
    "CLAUDE_AFK_TIMEOUT_MS": "2147483647",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "repo": "anthropics/skills",
        "source": "github"
      }
    },
    "goast": {
      "source": {
        "repo": "m-mizutani/goast",
        "source": "github"
      }
    },
    "m-mizutani-plugins": {
      "source": {
        "path": "/Users/mizutani/.ghq/github.com/m-mizutani/claude-code",
        "source": "directory"
      }
    },
    "sentry-mcp": {
      "source": {
        "repo": "getsentry/sentry-mcp",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "node /Users/mizutani/.claude/worktree-guard.mjs",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|MultiEdit|NotebookEdit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/mizutani/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "language": "明るく柔らかい敬語寄りで、馴れ馴れしすぎず、冗談や比喩を軽く挟みながら、常に一歩引いた余裕と少し含みのある飄々とした人物らしい言い回し",
  "model": "opus",
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.cloud.google.com)",
      "WebFetch(domain:zenn.dev)",
      "WebSearch",
      "Bash(npm run lint)",
      "Bash(npm run test:*)",
      "Bash(go test:*)",
      "Bash(go run:*)",
      "Bash(go mod:*)",
      "Bash(go get:*)",
      "Bash(go vet:*)",
      "Bash(go fmt:*)",
      "Bash(go list:*)",
      "Bash(go doc:*)",
      "Bash(go add:*)",
      "Bash(go checkout:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(mkdir:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(gh run list:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run view:*)",
      "Read(//Users/mizutani/.cache/go/pkg/**)",
      "WebFetch(domain:api.slack.com)",
      "WebFetch(domain:docs.slack.dev)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(sed *)",
      "Bash(npx *)",
      "Bash(git -C *)",
      "Bash(chmod *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(git push *)",
      "mcp__claude_ai_Slack"
    ],
    "defaultMode": "auto",
    "deny": [
      "Read(./.env)",
      "Read(./.env.yml)",
      "Read(./.env.yaml)",
      "Read(./secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Bash(sed:*)",
      "Bash(go build:*)",
      "Bash(kill:*)",
      "Bash(*/python* *)",
      "Bash(python* *)",
      "Bash(*/node *)",
      "Bash(node *)",
      "Bash(bash *)",
      "Bash(*/bash *)",
      "Bash(sh *)",
      "Bash(*/sh *)",
      "Bash(zsh *)",
      "Bash(*/zsh *)",
      "Bash(csh *)",
      "Bash(*/csh *)",
      "Bash(tcsh *)",
      "Bash(*/tcsh *)",
      "Bash(ksh *)",
      "Bash(*/ksh *)",
      "Bash(fish *)",
      "Bash(*/fish *)",
      "Bash(dash *)",
      "Bash(*/dash *)",
      "Bash(go build *)",
      "Bash(*/go build *)",
      "Bash(curl *)",
      "Bash(*/curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(gh pr comment:*)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "preferredNotifChannel": "terminal_bell",
  "sandbox": {
    "autoAllowBashIfSandboxed": false,
    "enabled": true,
    "excludedCommands": [
      "git:*",
      "gh:*",
      "difit:*",
      "go get:*",
      "go test:*",
      "pnpm test:*",
      "pnpm lint:*",
      "pnpm update:*",
      "pnpm upgrade:*",
      "gcloud:*",
      "docker:*",
      "bq:*",
      "npx difit:*",
      "mo:*",
      "task:*",
      "zenv:*"
    ],
    "filesystem": {
      "allowWrite": [
        "//tmp/claude-work",
        "~/.npm",
        "~/.cache",
        "~/.agent-browser",
        "~/Library/Caches",
        "~/go/pkg/mod/cache",
