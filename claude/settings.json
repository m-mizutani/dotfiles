    },
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "github.com",
        "proxy.golang.org",
        "google.golang.org",
        "ai.google.dev",
        "cloud.google.com",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org"
      ]
    }
  },
  "skipAutoPermissionPrompt": true,
  "statusLine": {
    "command": "node /Users/mizutani/.claude/statusline.mjs",
    "type": "command"
  },
  "worktree": {
    "symlinkDirectories": [
      "tmp",
      ".epic"
    ]
  }
}
