#!/usr/bin/env bash
set -euo pipefail

# git-ship: Auto-branch, commit (with AI message), push, and create PR.
# Dependencies: git, claude (Claude Code CLI), gh (GitHub CLI)

# --- Helpers ---

die() { echo "error: $1" >&2; exit 1; }

check_deps() {
  command -v claude >/dev/null 2>&1 || die "claude CLI not found"
  command -v gh >/dev/null 2>&1    || die "gh CLI not found"
}

get_default_branch() {
  # Try remote HEAD, fall back to main/master detection
  local ref
  ref=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@') || true
  if [ -z "$ref" ]; then
    if git show-ref --verify --quiet refs/heads/main 2>/dev/null; then
      ref="main"
    elif git show-ref --verify --quiet refs/heads/master 2>/dev/null; then
      ref="master"
    else
      die "cannot determine default branch"
    fi
  fi
  echo "$ref"
}

current_branch() {
  git rev-parse --abbrev-ref HEAD
}

has_staged_changes() {
  ! git diff --cached --quiet
}

has_unstaged_changes() {
  ! git diff --quiet || [ -n "$(git ls-files --others --exclude-standard)" ]
}

# --- Step 1: Branch if on default branch ---

ensure_feature_branch() {
  local default_branch
  default_branch=$(get_default_branch)
  local branch
  branch=$(current_branch)

  if [ "$branch" != "$default_branch" ]; then
    echo ">> On branch '$branch' (not default), skipping branch creation."
    return
  fi

  echo ">> On default branch '$default_branch'. Generating branch name..."

  local diff_summary
  # Use staged changes if any, otherwise unstaged + untracked file list
  if has_staged_changes; then
    diff_summary=$(git diff --cached --stat)
  else
    diff_summary=$(git diff --stat 2>/dev/null; git ls-files --others --exclude-standard)
  fi

  [ -z "$diff_summary" ] && die "no changes detected to base a branch name on"

  local branch_name
  branch_name=$(echo "$diff_summary" | claude --no-session-persistence --model claude-haiku-4-5 --print \
    'You are generating a git branch name. Based on the provided diff summary, generate ONLY a single branch name following git-flow conventions. Use one of these prefixes: feat/, fix/, docs/, refactor/, chore/, test/, ci/. The name part should be lowercase, use hyphens, and be concise (2-4 words max). Output ONLY the branch name. No explanation. No backticks. No markdown. Raw plain text only.')

  # Sanitize: remove whitespace, quotes, backticks
  branch_name=$(echo "$branch_name" | tr -d '[:space:]"'\''`')

  [ -z "$branch_name" ] && die "failed to generate branch name"

  echo ">> Creating branch: $branch_name"
  git checkout -b "$branch_name"
}

# --- Step 2: Stage & Commit ---

auto_commit() {
  # Stage all changes if nothing is staged
  if ! has_staged_changes; then
    if has_unstaged_changes; then
      echo ">> No staged changes. Staging all changes..."
      git add -A
    else
      die "no changes to commit"
    fi
  fi

  echo ">> Generating commit message..."
  local commit_msg
  commit_msg=$(git diff --cached | claude --no-session-persistence --model claude-haiku-4-5 --print \
    'You are generating a Conventional Commit message. Based strictly on the provided git diff, generate ONLY a one-line commit message using the Conventional Commits specification. Format: <type>(optional-scope): <imperative summary>. Rules: Use one of these types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert. Write the summary in imperative mood. Maximum ~72 characters. Do NOT include body text or explanation. Output ONLY the commit message line. Do NOT wrap the output in backticks, code blocks, or any markdown formatting. Output raw plain text only.')

  [ -z "$commit_msg" ] && die "failed to generate commit message"

  echo ">> Committing: $commit_msg"
  git commit -m "$commit_msg"
}

# --- Step 3: Push ---

push_to_remote() {
  local branch
  branch=$(current_branch)
  echo ">> Pushing '$branch' to origin..."
  git push -u origin "$branch"
}

# --- Step 4: Create PR if needed ---

ensure_pr() {
  local branch
  branch=$(current_branch)
  local default_branch
  default_branch=$(get_default_branch)

  # Don't create PR from default branch
  if [ "$branch" = "$default_branch" ]; then
    echo ">> On default branch, skipping PR creation."
    return
  fi

  # Check if PR already exists
  local existing_pr
  existing_pr=$(gh pr list --head "$branch" --json number --jq '.[0].number' 2>/dev/null || true)

  if [ -n "$existing_pr" ]; then
    echo ">> PR #$existing_pr already exists."
    gh pr view "$existing_pr" --web 2>/dev/null || true
    return
  fi

  echo ">> Creating PR..."

  # Generate PR title and body from the commits on this branch vs default
  local log_summary
  log_summary=$(git log "$default_branch".."$branch" --oneline 2>/dev/null || git log --oneline -5)

  local pr_info
  pr_info=$(echo "$log_summary" | claude --no-session-persistence --model claude-haiku-4-5 --print \
    'Based on the provided git log, generate a GitHub PR title and body. Output EXACTLY in this format (no other text):
TITLE: <short title under 70 chars>
BODY: <1-3 bullet points summarizing the changes, each on its own line starting with "- ">
Do NOT wrap in backticks or markdown code blocks. Raw plain text only.')

  local pr_title pr_body
  pr_title=$(echo "$pr_info" | grep '^TITLE:' | sed 's/^TITLE: *//')
  pr_body=$(echo "$pr_info" | sed -n '/^BODY:/,$ { s/^BODY: *//; p }')

  [ -z "$pr_title" ] && pr_title="$branch"
  [ -z "$pr_body" ] && pr_body="Auto-generated PR for branch $branch"

  gh pr create --title "$pr_title" --body "$pr_body"
}

# --- Main ---

main() {
  local create_branch=false

  while [ $# -gt 0 ]; do
    case "$1" in
      -b) create_branch=true; shift ;;
      *) die "unknown option: $1" ;;
    esac
  done

  # Ensure we're in a git repo
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not a git repository"

  check_deps

  if [ "$create_branch" = true ]; then
    ensure_feature_branch
  fi

  auto_commit
  push_to_remote
  ensure_pr

  echo ""
  echo ">> Done!"
}

main "$@"
