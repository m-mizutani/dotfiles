# Ghostty Configuration
# https://ghostty.org/docs/config/reference

# Theme and Colors - Brewer inspired
theme = Dark+
background-opacity = 0.85

# Font Settings - matching WezTerm
font-family = "Bizin Gothic"
font-size = 11
font-style = Bold
font-thicken = true
adjust-cell-width = 2%
adjust-cell-height = 7%

# Cursor
cursor-style = block
cursor-style-blink = false

# Window Settings - minimal padding like WezTerm
window-decoration = true
window-padding-x = 2
window-padding-y = 2
window-theme = dark

# Shell
shell-integration = detect
shell-integration-features = sudo,title,no-cursor

# Scrollback
scrollback-limit = 10000000

# Bell
bell-features = title,attention,border

# Misc
confirm-close-surface = false
quit-after-last-window-closed = false
auto-update = off

# ペイン移動
keybind = super+ctrl+h=goto_split:left
keybind = super+ctrl+l=goto_split:right
keybind = super+ctrl+k=goto_split:top
keybind = super+ctrl+j=goto_split:bottom

# ペインズーム
keybind = ctrl+z=toggle_split_zoom

keybind = ctrl+cmd+equal=equalize_splits

macos-titlebar-style = tabs

quick-terminal-position = "center"
quick-terminal-screen = "main"
quick-terminal-animation-duration = 0.3
keybind = "global:shift+ctrl+enter=toggle_quick_terminal"

term = xterm-256color

