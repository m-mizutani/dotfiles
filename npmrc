# --- npm / pnpm 共通 ---
# Takumi Guard: 既知の悪性パッケージをレジストリ前段でブロック
# https://flatt.tech/takumi/features/guard
registry=https://npm.flatt.tech/
# サプライチェーン対策: 公開直後の版を避ける
min-release-age=7
# install/postinstall などのライフサイクルスクリプトを実行しない
ignore-scripts=true
# `^` `~` を付けず固定バージョンで保存
save-exact=true
# npm 用ロックファイル
package-lock=true
# 募金メッセージ等を抑制
fund=false

# --- pnpm 固有 ---
# peerDependencies を自動インストール
auto-install-peers=true
# peer 依存の不整合を厳格に検出
strict-peer-dependencies=true
# 重複した peer を可能な範囲で集約
dedupe-peer-dependents=true
# package.json の engines を強制
engine-strict=true
# ホイスティングを抑制し isolated を維持
shamefully-hoist=false
node-linker=isolated
# workspace 依存の保存形式
save-workspace-protocol=rolling
# 実行前に依存の整合性を検証
verify-deps-before-run=warn
# 解決モードは時間ベース（互換性重視）
resolution-mode=time-based
# 更新通知を抑制
update-notifier=false
